const express = require('express');
const app = express();
app.use(express.json());

const PORT = 3001;

// Telegram конфигурация
const TELEGRAM_TOKEN = "8035891020:AAHi0dl82tdgLW5pAgW6nOAr0glQnIb0_mM";
const ADMIN_CHAT_ID = "472934740";

// ========== ТЕСТОВЫЙ ENDPOINT ==========
app.get('/api/test', (req, res) => {
    console.log('✅ /api/test вызван');
    res.json({
        status: 'success',
        service: 'Metodika Coffee Orders API',
        timestamp: new Date().toISOString(),
        port: PORT,
        endpoints: [
            'GET  /api/test',
            'POST /api/orders',
            'GET  /api/health'
        ]
    });
});

// ========== HEALTH CHECK ==========
app.get('/api/health', (req, res) => {
    res.json({ status: 'healthy', timestamp: new Date().toISOString() });
});

// ========== ПРОВЕРКА ПОДПИСКИ (УПРОЩЕННАЯ) ==========
app.post('/api/telegram/check-subscription', (req, res) => {
    const { telegramUserId } = req.body;
    console.log('🔐 Проверка подписки для пользователя:', telegramUserId);
    
    // Временно разрешаем всем
    res.json({
        success: true,
        subscribed: true,
        user: {
            id: telegramUserId || 0,
            firstName: 'Пользователь',
            lastName: 'Телеграм'
        },
        message: '✅ Добро пожаловать!'
    });
});

// ========== ОФОРМЛЕНИЕ ЗАКАЗА ==========
app.post('/api/orders', async (req, res) => {
    const order = req.body;
    const orderId = 'ORD-' + Date.now();
    
    console.log('\n' + '='.repeat(50));
    console.log('🛒 НОВЫЙ ЗАКАЗ #' + orderId);
    console.log('='.repeat(50));
    console.log('👤 Клиент:', order.userName || 'Не указано');
    console.log('📞 Телефон:', order.userPhone || 'Не указано');
    console.log('📍 Адрес:', order.deliveryAddress || 'Не указано');
    console.log('💰 Сумма:', order.totalAmount || 0, '₽');
    console.log('📝 Комментарий:', order.comment || 'Нет');
    if (order.items && order.items.length > 0) {
        console.log('📦 Товары:');
        order.items.forEach(item => {
            console.log(`   • ${item.name || 'Товар'} x${item.quantity || 1} - ${item.price || 0}₽`);
        });
    }
    console.log('='.repeat(50) + '\n');
    
    // Отправляем уведомление в Telegram
    let telegramSent = false;
    if (TELEGRAM_TOKEN && ADMIN_CHAT_ID) {
        try {
            const fetch = require('node-fetch');
            const message = `
🛍 <b>НОВЫЙ ЗАКАЗ #${orderId}</b>

👤 <b>Клиент:</b> ${order.userName || 'Не указано'}
📞 <b>Телефон:</b> ${order.userPhone || 'Не указано'}
📍 <b>Адрес:</b> ${order.deliveryAddress || 'Не указано'}
💰 <b>Сумма:</b> ${order.totalAmount || 0}₽

${order.items && order.items.length > 0 ? 
`📦 <b>Заказ:</b>
${order.items.map(item => `• ${item.name || 'Товар'} x${item.quantity || 1} - ${item.price || 0}₽`).join('\n')}` : ''}

${order.comment ? `📝 <b>Комментарий:</b> ${order.comment}` : ''}
            `.trim();
            
            const response = await fetch(`https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    chat_id: ADMIN_CHAT_ID,
                    text: message,
                    parse_mode: 'HTML'
                })
            });
            
            const result = await response.json();
            if (result.ok) {
                console.log('✅ Уведомление отправлено в Telegram');
                telegramSent = true;
            } else {
                console.log('❌ Ошибка Telegram:', result.description);
            }
        } catch (error) {
            console.error('❌ Ошибка отправки в Telegram:', error.message);
        }
    }
    
    res.json({
        success: true,
        orderId: orderId,
        message: `Заказ принят!${telegramSent ? ' Уведомление отправлено.' : ''}`,
        telegramSent: telegramSent
    });
});

// ========== ЗАПУСК СЕРВЕРА ==========
app.listen(PORT, '0.0.0.0', () => {
    console.log('\n' + '='.repeat(50));
    console.log('🚀 METODIKA COFFEE ORDERS API');
    console.log('='.repeat(50));
    console.log(`📡 Порт: ${PORT}`);
    console.log(`🌐 URL: http://localhost:${PORT}`);
    console.log('');
    console.log('✅ Доступные endpoint:');
    console.log(`   GET  http://localhost:${PORT}/api/test`);
    console.log(`   POST http://localhost:${PORT}/api/orders`);
    console.log(`   GET  http://localhost:${PORT}/api/health`);
    console.log('');
    console.log('🤖 Telegram:');
    console.log(`   Токен: ${TELEGRAM_TOKEN ? '✅ настроен' : '❌ не настроен'}`);
    console.log(`   Админ: ${ADMIN_CHAT_ID || 'не указан'}`);
    console.log('='.repeat(50) + '\n');
});
